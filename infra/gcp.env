# GCP project configuration — single source of truth.
# To move to a different project:
#   1. Edit GCP_PROJECT_ID and GCP_PROJECT_NUMBER here.
#   2. Re-run  bash infra/setup.sh
#   3. Create a new Cloud Build GitHub trigger in the new project.
#      (cloudbuild.yaml uses ${PROJECT_ID} set automatically by Cloud Build,
#       so the YAML file itself does not need to change.)

GCP_PROJECT_ID=game-app-as
GCP_PROJECT_NUMBER=427039053620
GCP_REGION=asia-northeast1

# Cloud Run service names
GCP_MAIN_SERVICE=aivtuber
GCP_VOICEVOX_SERVICE=voicevox

# Artifact Registry repository name
GCP_AR_REPO=aivtuber

# VOICEVOX default speaker (can be overridden in Cloud Build trigger substitutions)
VOICEVOX_SPEAKER_ID=1
