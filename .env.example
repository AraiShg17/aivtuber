# YouTube Data API v3 key
YOUTUBE_API_KEY=

# YouTube Video ID (can also be passed as ?videoId= query param in OBS browser source URL)
YOUTUBE_VIDEO_ID=

# OpenAI API Key — use Secret Manager in production
OPENAI_API_KEY=

# Firebase / Firestore
FIREBASE_PROJECT_ID=
# Local dev only: path to service account key (Cloud Run uses ADC automatically)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# VOICEVOX
VOICEVOX_URL=http://localhost:50021
VOICEVOX_SPEAKER_ID=1
