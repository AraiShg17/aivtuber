# .env.example → .env.local にコピーして値を入れてください

# YouTube Data API v3
YOUTUBE_API_KEY=

# デフォルトの動画ID（OBS ブラウザソース URL に ?videoId= で上書き可）
YOUTUBE_VIDEO_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# 音声合成エンジン
# voicevox: docker run -p 50021:50021 voicevox/voicevox_engine:cpu-ubuntu20.04-latest
# aivis   : AivisSpeech を起動 (VOICEVOX 互換 API、より自然な音声) → 乗り換え予定
TTS_PROVIDER=voicevox
VOICEVOX_URL=http://localhost:50021
# AivisSpeech に切り替える場合:
# TTS_PROVIDER=aivis
# VOICEVOX_URL=http://localhost:10101
VOICEVOX_SPEAKER_ID=1

# Firestore
FIREBASE_PROJECT_ID=aivtuber-project-app
FIREBASE_DATABASE_ID=aivtuber-memory
# ローカル認証: gcloud auth application-default login で取得した ADC を使用
# GOOGLE_APPLICATION_CREDENTIALS は不要（ADC で自動解決）
