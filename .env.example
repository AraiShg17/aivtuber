# .env.example → .env.local にコピーして値を入れてください

# YouTube Data API v3
YOUTUBE_API_KEY=

# デフォルトの動画ID（OBS ブラウザソース URL に ?videoId= で上書き可）
YOUTUBE_VIDEO_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# VOICEVOX (ローカル起動: docker run -p 50021:50021 voicevox/voicevox_engine:cpu-ubuntu20.04-latest)
VOICEVOX_URL=http://localhost:50021
VOICEVOX_SPEAKER_ID=1

# Firestore
FIREBASE_PROJECT_ID=aivtuber-project-app
FIREBASE_DATABASE_ID=aivtuber-memory
# ローカル認証: gcloud auth application-default login で取得した ADC を使用
# GOOGLE_APPLICATION_CREDENTIALS は不要（ADC で自動解決）
